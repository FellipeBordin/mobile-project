generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VehicleStatus {
  IN_STOCK
  SOLD
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vehicles     Vehicle[]

  @@index([email])
}

model Vehicle {
  id            String        @id @default(cuid())
  name          String
  plate         String        @unique
  status        VehicleStatus @default(IN_STOCK)

  purchasePrice Decimal
  purchaseDate  DateTime?

  soldPrice     Decimal?
  soldDate      DateTime?

  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  expenses      Expense[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model Expense {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  amount    Decimal
  note      String?
  createdAt DateTime @default(now())

  @@index([vehicleId])
}